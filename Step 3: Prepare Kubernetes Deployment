apiVersion: apps/v1
kind: Deployment
metadata:
  name: conference-app-deployment
spec:
  replicas: 1
  selector:
    matchLabels:
      app: conference-app
  template:
    metadata:
      labels:
        app: conference-app
    spec:
      containers:
      - name: conference-app
        image: conference-web-app:latest
        imagePullPolicy: Never 
        ports:
        - containerPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: conference-app-service
spec:
  type: NodePort
  selector:
    app: conference-app
  ports:
    - port: 80
      targetPort: 80
      nodePort: 30080
